ARCH=sim
TARGET=sim
SIGN?=RSA4096
HASH?=SHA384
WOLFBOOT_SMALL_STACK?=0
SPI_FLASH=0
DEBUG=0
SPMATH=1

# RSA4096 image signature path needs the larger stack and header
WOLFBOOT_HUGE_STACK=1
IMAGE_HEADER_SIZE=4096

# Cert chain options:
#   - CA chain (root + intermediate) signed with ECC256 + SHA256
#   - Leaf cert identity is RSA4096 (signs the wolfBoot image with SHA384)
#   - CERT_CHAIN_PK=ecc256 links ECC verify into wolfCrypt for chain validation
CERT_CHAIN_VERIFY=1
CERT_CHAIN_CA_ALGO=ecc256
CERT_CHAIN_LEAF_ALGO=rsa4096
CERT_CHAIN_CA_HASH=sha256
CERT_CHAIN_PK=ecc256

# wolfHSM options
WOLFHSM_CLIENT=1

# sizes should be multiple of system page size
WOLFBOOT_PARTITION_SIZE=0x200000
WOLFBOOT_SECTOR_SIZE=0x1000
WOLFBOOT_PARTITION_BOOT_ADDRESS=0x80000
WOLFBOOT_PARTITION_UPDATE_ADDRESS=0x280000
WOLFBOOT_PARTITION_SWAP_ADDRESS=0x480000

# required for keytools
WOLFBOOT_FIXED_PARTITIONS=1

# For debugging XMALLOC/XFREE
#CFLAGS_EXTRA+=-DWOLFBOOT_DEBUG_MALLOC
